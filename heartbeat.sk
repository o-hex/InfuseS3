every 5 ticks:
    loop all players:
        # if has_infuse(loop-player, "frost") is true:
        #     loop blocks in radius 2 around loop-player:
        #         if loop-block is water:
        #             update loop-block to be frosted ice
        {infuse::disabled::%{_u}%} is not set

        if loop-player is burning:
            if has_infuse(loop-player, "fire") is true:
                clear {_blocks::*}
                clear {_blocks_location::*}
                loop all blocks in radius 3 around loop-player:
                    if loop-block is water:
                        add loop-block to {_blocks::*}
                        add location of loop-block to {_blocks_location::*}

                update {_blocks::*} to be air
                force draw (1 gray dust particles of size 5 with an extra value of 0.5) at {_blocks_location::*}
                play sound "block.lava.extinguish" at {_p}

            set {_canSpread} to false
            loop all players in radius 6 of loop-player:
                if has_infuse(loop-player-2, "fire") is true:
                    set {_canSpread} to true
                    exit loop

            if {_canSpread} is true:
                loop all players in radius 1.5 of loop-player:
                    loop-player-2 is not loop-player-1

                    ignite loop-player-2 for 10 seconds
                    force draw (5 flame particles with an extra value of 0.5) at loop-player-2
                    play sound "block.fire.ambient" with volume 0.7 at loop-player-2

