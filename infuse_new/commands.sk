command /conf [<text>] [<text>] [<text>] [<text>]:
    permission: op
    prefix: infuse
    trigger:
        if arg-1 is "get":
            if arg-3 is set:
                if {-infuse::config::%arg-2%::%arg-3%} is set:
                    send "<yellow>%arg-2% %arg-3% <gray>is: <white>%{-infuse::config::%arg-2%::%arg-3%}%"
                else:
                    send "%{@prefix}%<red>Key '<yellow>%arg-3%<red>' not found in category '<yellow>%arg-2%<red>'."
            else if arg-2 is set:
                set {_keys::*} to all indices of {-infuse::config::%arg-2%::*}
                if size of {_keys::*} > 0:
                    send "<gold><strikethrough>   <reset> <yellow>%arg-2% <gold><strikethrough>   "
                    loop {_keys::*}:
                        send " <yellow>%loop-value%: <white>%{-infuse::config::%arg-2%::%loop-value%}%"
                else if {-infuse::config::%arg-2%} is set:
                    send "<yellow>%arg-2% <gray>is: <white>%{-infuse::config::%arg-2%}%"
                else:
                    send "%{@prefix}%<red>'<yellow>%arg-2%<red>' is not a valid category or key."
            else:
                send "<gold>All config keys/categories: <white>%all indices of {-infuse::config::*}%"
        else if arg-1 is "set":
            if arg-4 is set:
                set {_raw} to arg-4
                if {_raw} matches "^-?[0-9]+(\\.[0-9]+)?$":
                    set {-infuse::config::%arg-2%::%arg-3%} to {_raw} parsed as number
                else if {_raw} is "true" or "false":
                    set {-infuse::config::%arg-2%::%arg-3%} to {_raw} parsed as boolean
                else:
                    set {-infuse::config::%arg-2%::%arg-3%} to {_raw}
                send "%{@prefix}%<white>Updated <yellow>%arg-2% %arg-3% <green>to <white>%arg-4%"
            else if arg-3 is set:
                set {_raw} to arg-3
                if {_raw} matches "^-?[0-9]+(\\.[0-9]+)?$":
                    set {-infuse::config::%arg-2%} to {_raw} parsed as number
                else if {_raw} is "true" or "false":
                    set {-infuse::config::%arg-2%} to {_raw} parsed as boolean
                else:
                    set {-infuse::config::%arg-2%} to {_raw}
                send "%{@prefix}%<white>Updated <yellow>%arg-2% <green>to <white>%arg-3%"
            else:
                send "<red>Usage: /conf set <key> <value>"
                send "<red>Usage: /conf set <category> <key> <value>"
        else if arg-1 is "list":
            if arg-2 is "show":
                if arg-3 is not set:
                    send "<red>Usage: /conf list show <listname>"
                    stop
                set {_items::*} to {-infuse::config::%arg-3%::*}
                if size of {_items::*} > 0:
                    send "<gold><strikethrough>    <reset><yellow>%arg-3% <gold>(%size of {_items::*}% entries)<gold><strikethrough>    "
                    loop {_items::*}:
                        send " <gray>%loop-index%. <white>%loop-value%"
                else:
                    send "%{@prefix}%<red>List '<yellow>%arg-3%<red>' is empty or does not exist."
            else if arg-2 is "add":
                if arg-4 is not set:
                    send "<red>Usage: /conf list add <listname> <value>"
                    stop
                add arg-4 to {-infuse::config::%arg-3%::*}
                send "%{@prefix}%<white>Added <yellow>%arg-4% <green>to list <yellow>%arg-3%<green>."
            else if arg-2 is "remove":
                if arg-4 is not set:
                    send "<red>Usage: /conf list remove <listname> <value>"
                    stop
                remove arg-4 from {-infuse::config::%arg-3%::*}
                send "%{@prefix}%<white>Removed <yellow>%arg-4% <red>from list <yellow>%arg-3%<red>."
            else if arg-2 is "clear":
                if arg-3 is not set:
                    send "<red>Usage: /conf list clear <listname>"
                    stop
                clear {-infuse::config::%arg-3%::*}
                send "%{@prefix}%<white>Cleared list <yellow>%arg-3%<white>."
            else:
                send "<gold><strikethrough>                                                     <reset>"
                send " <yellow>/conf list show <listname>          <gray>view contents"
                send " <yellow>/conf list add <listname> <value>   <gray>append an entry"
                send " <yellow>/conf list remove <listname> <value><gray>remove an entry"
                send " <yellow>/conf list clear <listname>         <gray>wipe the list"
                send "<gold><strikethrough>                                                     <reset>"
        else:
            send "<gold><strikethrough>                                                     <reset>"
            send " <yellow>/conf get <dark_gray>[category] [key]"
            send " <yellow>/conf set <dark_gray><key> <value>"
            send " <yellow>/conf set <dark_gray><category> <key> <value>"
            send " <yellow>/conf list <dark_gray><show|add|remove|clear> <listname> [value]"
            send " <gray>Lists: <white>primary_effects<gray>, <white>secondary_effects"
            send "<gold><strikethrough>                                                     <reset>"

command /item <text> [<boolean>]:
    usage: <red>/item <effect> <augment?boolean>
    aliases: /giveitem, /i, /potion, /pot
    permission: op
    prefix: infuse
    trigger:
        if arg-1 is not "all":
            set {_i} to get_item(arg-1, arg-2 ? false)
            give player 1 of {_i}
        else:
            loop {infuse::effects::*}:
                loop-value is not "earth" or "ender"
                give player 1 of get_item(loop-value, false)
                give player 1 of get_item(loop-value, true)

command /ldrain:
    aliases: /pdrain
    description: Drains the left (primary) slot
    prefix: infuse
    trigger:
        drain_effect(player, "primary")

command /rdrain:
    aliases: /sdrain
    description: Drains the right (secondary) slot
    prefix: infuse
    trigger:
        drain_effect(player, "secondary")

