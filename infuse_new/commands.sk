options:
    prefix: "<yellow>[i] <gray>» <reset>"
on tab complete of "/infuse" or "/infuse:infuse":
    set {_action} to tab arg-1
    if tab arg-2 is not set:
        set tab completions for position 1 to "add", "remove", "history", "toggle" and "get"
        stop
    set {_i} to 2
    loop 4 times:
        set {_current} to tab arg-{_i}
        if {_current} is "":
            set tab completions for position {_i} to "-p=", "-e=", "-s=", and "-a="
        else if {_current} does not contain "=":
            set {_flags::*} to "-p=", "-e=", "-s=", and "-a="
            loop {_flags::*}:
                if loop-value-2 starts with {_current}:
                    add loop-value-2 to {_match::*}
            set tab completions for position {_i} to {_match::*}
        else if {_current} starts with "-p=":
            loop all players:
                add "-p=%loop-player%" to {_vals::*}
            set tab completions for position {_i} to {_vals::*}
        else if {_current} starts with "-e=":
            loop {infuse::effects::*}:
                add "-e=%loop-value-2%" to {_vals::*}
            set tab completions for position {_i} to {_vals::*}
        else if {_current} starts with "-s=":
            set tab completions for position {_i} to "-s=primary" and "-s=secondary"
        else if {_current} starts with "-a=":
            set tab completions for position {_i} to "-a=true" and "-a=false"
        add 1 to {_i}

on tab complete of "/conf" or "/infuse:conf":
    set tab completions for position 1 to "get" and "set"
    if tab arg-1 is "get" or "set":
        set tab completions for position 2 to all indices of {-infuse::config::*}
        if tab arg-2 is set:
            set tab completions for position 3 to all indices of {-infuse::config::%tab arg-2%::*}

on tab complete of "/use", "/u", "/activate", "/a", "/infuse:use", "/infuse:u", "/infuse:activate" and "/infuse:a":
    set tab completions for position 1 to "primary", "secondary", "p" and "u"

on tab complete of "/trust", "/t", "/infuse:trust" or "/infuse:t":
    set tab completions for position 1 to "add", "remove", "list" and "clear"
    if tab arg-1 is "add" or "remove":
        set tab completions for position 2 to all players

on tab complete of "/bind" or "/infuse:bind":
    set tab completions for position 1 to "primary" and "secondary"
    set tab completions for position 2 to "swap", "drop", "sneak", "sneak-drop", "sneak-swap" and "none"

on tab complete of "/item", "/giveitem", "/potion", "/pot", "/i", "/infuse:item", "/infuse:giveitem", "/infuse:potion", "/infuse:pot" and "/infuse:i":
    set tab completions for position 1 to ({infuse::effects::*} except "earth")
    set tab completions for position 2 to "true" and "false"

on tab complete of "/resetcooldown", "/rsc", "/rscd", "/rcd", "/rscooldown", "/infuse:resetcooldown", "/infuse:rsc", "/infuse:rscd", "/infuse:rcd" and "/infuse:rscooldown":
    set tab completions for position 1 to "primary" and "secondary"

on tab complete of "/resetcraft", "/rsc", "/rscraft", "/infuse:resetcraft", "/infuse:rsc" and "/infuse:rscraft":
    set tab completions for position 1 to  ({infuse::effects::*} except "earth")

command /trust <text> [<text>]:
    usage: <red>Usage: /trust <add|remove|list|clear> [<player>]
    description: Manages the people inside your trust list to be exempted from your effects.
    prefix: infuse
    aliases: /t
    executable by: players
    trigger:
        set {_u} to uuid of sender
        if arg-1 is "add" or "remove":
            set {_p} to arg-2 parsed as offline player
            if {_p} is not set:
                send "%{@prefix}%<red>Please specify a valid player."
                stop
            set {_target} to uuid of {_p}
            if arg-1 is "add":
                if size of {infuse::trust::%{_u}%::*} >= {-infuse::config::trust_list_max}:
                    if sender does not have permission "trust.bypass_limit":
                        send "%{@prefix}%<red>You have reached your limit of trusted players."
                        stop

                if {infuse::trust::%{_u}%::%{_target}%} is set:
                    send "%{@prefix}%<gray>%{_p}% is <green>already <gray>trusted."
                else:
                    send "%{@prefix}%<yellow>Action Pending..."
                    wait {-infuse::config::trust_list_delay}
                    set {infuse::trust::%{_u}%::%{_target}%} to {_target}
                    send "%{@prefix}%<gray>Added <white>%{_p}%<gray>."
            
            else if arg-1 is "remove":
                if {infuse::trust::%{_u}%::%{_target}%} is not set:
                    send "%{@prefix}%<white>%{_p}% <gray>is not trusted."
                else:
                    send "%{@prefix}%<yellow>Action Pending..."
                    wait {-infuse::config::trust_list_delay}
                    delete {infuse::trust::%{_u}%::%{_target}%}
                    send "%{@prefix}%<gray>Removed <white>%{_p}%<gray>."

        else if arg-1 is "clear":
            send "%{@prefix}%<yellow>Action Pending..."
            wait {-infuse::config::trust_list_delay}
            delete {infuse::trust::%{_u}%::*}
            send "%{@prefix}%<gray>List cleared."

        else if arg-1 is "list":
            set {_size} to size of {infuse::trust::%{_u}%::*}
            if {_size} is 0:
                send "%{@prefix}%<gray>List is empty."
                stop
            
            send "<yellow><bold>TRUST LIST <dark_gray>(<white>%{_size}%<dark_gray>/<gray>%{-infuse::config::trust_list_max}%<dark_gray>) <dark_gray><strikethrough>        <reset>"
            loop {infuse::trust::%{_u}%::*}:
                add 1 to {_c}
                send "<yellow>%{_c}%. <white>%loop-value parsed as offline player% <dark_gray>(<gray>%loop-value%<dark_gray>)"
        else:
            send "%{@prefix}%<red>Use add, remove, list, or clear."

command /use [<text>]:
    usage: <red>Usage: /use <(primary|p)|(secondary|s)>
    description: Triggers the infuse sparks in your primary and secondary effect slots.
    prefix: infuse
    aliases: /u, /a, /activate
    executable by: players
    trigger:
        set {_u} to uuid of player
        set {_s} to arg-1 ? "primary"
        set {_s} to "primary" if {_s} is "p"
        set {_s} to "secondary" if {_s} is "s"

        if {_s} is not "primary" or "secondary":
            send "<red>Usage: /use <primary|secondary>" to player
            stop

        set {_e} to {infuse::stats::%{_u}%::%{_s}%}
        
        if {_e} is set:
            set {_spark} to {-infuse::config::%{_e}%::spark}
            set {_cd} to {-infuse::config::%{_e}%::cd}
            spark_start(player, {_s}, {_spark}, {_cd})
        else:
            send "%{@prefix}%<red>You don't have an effect equipped in your %{_s}% slot!" to player

command /infuse [<text>] [<text>]:
    usage: <red>/infuse <add|remove|get|history> -p=<player> -e=<effect> -a=<boolean> -s=<slot>
    description: Manages infuse effects for players.
    prefix: infuse
    permission: op
    trigger:
        set {_v} to argument 1
        set {_i} to argument 2

        if {_v} is not "add", "remove", "get", "history" or "toggle":
            send "<red>Usage: /infuse <add|remove|get|history|toggle> [flags]"
            stop

        loop ({_i} split at " "):
            set {_lv} to loop-value
            if {_lv} matches "-p=.+":
                set {_p} to {_lv}
                replace "-p=" with "" in {_p}
            else if {_lv} matches "-e=.+":
                set {_e} to {_lv}
                replace "-e=" with "" in {_e}
            else if {_lv} matches "-a=.+":
                set {_a} to {_lv}
                replace "-a=" with "" in {_a}
            else if {_lv} matches "-s=.+":
                set {_s} to {_lv}
                replace "-s=" with "" in {_s}

        if {_p} is set:
            set {_t} to {_p} parsed as player
            if {_t} is not set:
                send "%{@prefix}%<red>Player '%{_p}%' not found."
                stop

        else:
            if sender is a player:
                set {_t} to sender
            else:
                send "%{@prefix}%<red>You must specify a player with -p=<name>."
                stop

        set {_uuid} to uuid of {_t}

        if {_v} is "remove":
            if {_s} is not set:
                set_infuse({_t}, "primary", "none", false)
                set_infuse({_t}, "secondary", "none", false)
                send "%{@prefix}%Removed effects from both slots of %{_t}%"
                stop

            set_infuse({_t}, {_s}, "none", false)
            send "%{@prefix}%<yellow>Removed effect from %{_t}%'s %{_s}% slot."

        else if {_v} is "add":
            if {infuse::effects::*} does not contain {_e}:
                send "%{@prefix}%<red>Invalid effect. Valid effects: %{infuse::effects::*}%"
                stop
            set {_aug} to false
            if {_a} is "true":
                set {_aug} to true
            if {_s} is not set:
                set_infuse({_t}, "primary", {_e}, {_aug})
                set_infuse({_t}, "secondary", {_e}, {_aug})
                send "%{@prefix}%<white>Applied <green><bold>%{_e}%<reset><white> to both slots of %{_t}% (augmented: %{_aug}%)."
                stop
            set_infuse({_t}, {_s}, {_e}, {_aug})
            send "%{@prefix}%<white>Applied <green><bold>%{_e}%<reset><white> to %{_t}%'s %{_s}% slot (augmented: %{_aug}%)."

        else if {_v} is "get":
            if {_s} is set:
                set {_eff} to {infuse::stats::%{_uuid}%::%{_s}%}
                set {_aug} to {infuse::stats::%{_uuid}%::%{_s}%::a} ? false
                send "<yellow>[%{_s}%] <white>%{_eff}% <gray>(augmented: %{_aug}%)"
            else:
                set {_pEff} to {infuse::stats::%{_uuid}%::primary}
                set {_pAug} to {infuse::stats::%{_uuid}%::primary::a} ? false
                set {_sEff} to {infuse::stats::%{_uuid}%::secondary}
                set {_sAug} to {infuse::stats::%{_uuid}%::secondary::a} ? false
                send "<yellow>primary <gray>» <white>%{_pEff}% <gray>(augmented: %{_pAug}%)"
                send "<yellow>secondary <gray>» <white>%{_sEff}% <gray>(augmented: %{_sAug}%)"

        else if {_v} is "history":
            if {_s} is not set:
                send "%{@prefix}%You must specify a slot with -s=<slot>."
                stop
            set {_hist::*} to {infuse::history::%{_uuid}%::%{_s}%::*}
            if size of {_hist::*} is 0:
                send "%{@prefix}%<gray>No history found for %{_t}%'s %{_s}% slot."
                stop
            send "<gray><strikethrough>         <reset> <yellow> History: %{_t}% [%{_s}%] <gray><strikethrough>         <reset>"
            send ""
            loop {_hist::*}:
                set {_parts::*} to loop-value split at ":"
                set {_hEff} to {_parts::1}
                set {_hAug} to {_parts::2}
                set {_hTs} to {_parts::3}
                send "<gray>%loop-index%. <white>%{_hEff}% <gray>(aug: %{_hAug}%) <dark_gray>@ <gray>%{_hTs}% ms"
            # send ""
            # send "<gold><strikethrough>                                                     <reset>"
        else if {_v} is "toggle":
            if {_s} is set:
                send "%{@prefix}%You cannot disable a specific slot."
                stop
            set {_ds} to {infuse::disabled::%{_uuid}%}
            if {_ds} is not set:
                set {infuse::disabled::%{_uuid}%} to true
                send "%{@prefix}%Disabled infuse for %{_t}%"
                if sender is not {_t}:
                    send "%{@prefix}%Your effects have been disabled" to {_t}
            else:
                clear {infuse::disabled::%{_uuid}%}
                send "%{@prefix}%Enabled infuse for %{_t}%"
                if sender is not {_t}:
                    send "%{@prefix}%Your effects have been enabled" to {_t}


command /bind [<text>] [<text>]:
    usage: <red>/bind <primary|secondary> <swap|drop|sneak|sneak-drop|sneak-swap|none>
    prefix: infuse
    aliases: /controlset, /controls, /control
    executable by: players
    trigger:
        set {_s} to arg-1
        set {_a} to arg-2
        
        if {_s} is not "primary" or "secondary":
            send "<red>Specify slot: primary or secondary"
            stop

        if {_a} is not "swap", "drop", "sneak", "sneak-drop", "sneak-swap" or "none":
            send "<red>Specify action: swap, drop, sneak, sneak-drop, sneak-swap, or none"
            stop
            
        set {infuse::stats::%uuid of player%::bind::%{_s}%} to {_a}
        send "%{@prefix}%<white>Bound <white>%{_s}% <green>slot to <white>%{_a}%<green>."

command /swap:
    prefix: infuse
    aliases: /swapeff, /swapeffects, /swapslots
    executable by: players
    trigger:
        set {_oL} to {infuse::stats::%uuid of player%::primary}
        set {_oR} to {infuse::stats::%uuid of player%::secondary}
        set {_aL} to {infuse::stats::%uuid of player%::primary::a}
        set {_aR} to {infuse::stats::%uuid of player%::secondary::a}

        set_infuse(player, "primary", {_oR}, {_aR} ? false)
        set_infuse(player, "secondary", {_oL}, {_aL} ? false)
        send "%{@prefix}%<white>Swapped your effects."

command /toggledisplay:
    prefix: infuse
    aliases: /display, /toggleicon, /simpleicon
    executable by: players
    trigger:
        set {_o} to {infuse::stats::%uuid of player%::display_icon} ? true
        
        if {_o} is true:
            set {infuse::stats::%uuid of player%::display_icon} to false
        else:
            set {infuse::stats::%uuid of player%::display_icon} to true
        send "%{@prefix}%<white>Toggled display style."


        
command /resetcraft [<text>]:
    usage: <red>Usage: /resetcraft [<effects>]
    description: Resets the craft limit (the counter) saved in the server
    prefix: infuse 
    aliases: /rsc, /rscraft
    permission: op
    trigger:
        set {_e} to arg-1
        if {_e} is not set:
            loop {infuse::effects::*}:
                if loop-value is not "earth" or "ender":
                    clear {infuse::ritual::%loop-value%::crafted}
                    send "%{@prefix}%<gray>%loop-value%<gray>: %{infuse::ritual::%loop-value%::crafted} ? 0% <dark_gray>-> <yellow>0"
            send "%{@prefix}%<white>Reset the effect crafting tally counter for all effects"
        else:
            if {infuse::effects::*} does not contain {_e}:
                send "<red>""%arg-1%"" is not a valid effect"
            else:
                clear {infuse::ritual::%{_e}%::crafted}
                send "%{@prefix}%<white>Reset the effect crafting tally counter for the %arg-1% effect"
                send "%{@prefix}%<white>Original value: %{infuse::ritual::%{_e}%::crafted} ? 0%"

command /resetcooldown [<text>]:
    usage: <red>Usage: /resetcooldown [primary|secondary]
    description: Resets the cooldown for your primary and secondary effects
    executable by: players
    aliases: /rsc, /rscd, /rcd, /rscooldown
    permission: op
    trigger:
        set {_p} to {infuse::stats::%uuid of player%::primary}
        set {_s} to {infuse::stats::%uuid of player%::secondary}
        if arg-1 is "primary":
            if ({infuse::active::%uuid of player%::%{_p}%::s} ? 0) > 0:
                send "%{@prefix}%<red>Your primary spark is still active, wait for it to end."
                stop
            send "%{@prefix}%<white>Reset the cooldown for your <aqua>primary <white>slot."
            cooldown_end(player, {_p})
        else if arg-1 is "secondary":
            if ({infuse::active::%uuid of player%::%{_s}%::s} ? 0) > 0:
                send "%{@prefix}%<red>Your secondary spark is still active, wait for it to end."
                stop
            send "%{@prefix}%<white>Reset the cooldown for your <aqua>secondary <white>slot."
            cooldown_end(player, {_s})
        else:
            if ({infuse::active::%uuid of player%::%{_p}%::s} ? 0) + ({infuse::active::%uuid of player%::%{_s}%::s} ? 0) > 0:
                send "%{@prefix}%<red>One of your sparks is still active, wait for it to end."
                stop
            send "%{@prefix}%<white>Reset the cooldown for <aqua>both <white>infuse slots."
            cooldown_end(player, {_p})
            cooldown_end(player, {_s})

