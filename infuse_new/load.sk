#  ███▒      ███▒      ███▒         █████▒▒██████ ▒▒████████▒▒████████ █████████
# ▒▒▒       ▒▒▒       ▒▒▒          ▒▒▒▒▒  ▒▒▒▒▒▒   ▒▒▒▒▒▒▒▒  ▒▒▒▒▒▒▒▒ ▒▒▒▒▒▒▒▒▒ 
                                                                              
on load:
    # if {-infuse::config::skip_initialization} is true:
    #     stop

    clear {infuse::effects::*}
    clear {infuse::active::*}

    clear {-infuse::flags::*}
    clear {-infuse::icon::*}
    clear {-infuse::bar::*}

    add all mobs to team named "invis-effect"
    set team option collision rule of team named "invis-effect" to never
    set allow friendly fire team state of team named "invis-effect" to true
    set can see friendly invisibles team state of team named "invis-effect" to false

    add "earth", "emerald", "ender", "feather", "fire" and "frost" to {infuse::effects::*}
    add "haste", "heart", "invisibility", "ocean" and "regeneration" to {infuse::effects::*}
    add "speed", "strength" and "thunder" to {infuse::effects::*}

    set {_n::*} to {infuse::effects::*}
    set {_c} to htd("E000")
    set {_b} to htd("E484")
    loop {_n::*}:
        set {_v} to loop-value
        if {_v} is "earth" or "ender":
            loop 21 times:
                set {_i} to loop-iteration-2
                set {-infuse::icon::%{_v}%::augmented-normal::%{_i}%} to character from code point ({_c} + {_i}-1) # sk:ne
                set {-infuse::icon::%{_v}%::augmented-spark::%{_i}%} to character from code point ({_c} + 21 + {_i}-1) # sk:ne
            add 42 to {_c} # sk:ne
        else:
            loop 21 times:
                set {_i} to loop-iteration-2
                set {-infuse::icon::%{_v}%::default-normal::%{_i}%} to character from code point ({_c} + {_i}-1) # sk:ne
                set {-infuse::icon::%{_v}%::augmented-normal::%{_i}%} to character from code point ({_c} + 21 + {_i}-1) # sk:ne
                set {-infuse::icon::%{_v}%::augmented-spark::%{_i}%} to character from code point ({_c} + 42 + {_i}-1) # sk:ne
                set {-infuse::icon::%{_v}%::default-spark::%{_i}%} to character from code point ({_c} + 63 + {_i}-1) # sk:ne
            add 84 to {_c} # sk:ne
        loop 14 times:
            set {_i} to loop-iteration-2
            if {_i} <= 10:
                set {-infuse::bar::%{_v}%::recharge::%{_i}%} to character from code point ({_b} + {_i}-1) # sk:ne
            else:
                set {-infuse::bar::%{_v}%::charged::%({_i} - 10)%} to character from code point ({_b} + {_i}-1) # sk:ne
        add 14 to {_b}

    set {-infuse::flags::lava_replace::*} to magma block, basalt, obsidian and netherrack
    set {-infuse::flags::frost_replace::*} to ice, packed ice, blue ice and snow block
    set {-infuse::flags::axes::*} to wooden axe, stone axe, iron axe, golden axe, diamond axe, netherite axe and "copper axe" parsed as item type

    set {-infuse::flags::looting_enchanted::*} to wooden sword, stone sword, iron sword, golden sword, diamond sword, netherite sword, "copper sword" parsed as item type and {-infuse::flags::axes::*}
    set {-infuse::flags::fortune_enchanted::*} to wooden pickaxe, stone pickaxe, iron pickaxe, golden pickaxe, diamond pickaxe, netherite pickaxe, wooden shovel, stone shovel, iron shovel, golden shovel, diamond shovel, netherite shovel, wooden hoe, stone hoe, iron hoe, golden hoe, diamond hoe, netherite hoe, "copper pickaxe" parsed as item type, "copper shovel" parsed as item type and "copper hoe" parsed as item type 
    set {-infuse::flags::tools::*} to {-infuse::flags::looting_enchanted::*} and {-infuse::flags::fortune_enchanted::*}

    add (bread), (cooked beef), (cooked chicken), (cooked mutton), (cooked porkchop) and (cooked rabbit) to {-infuse::flags::consumable_items::*}
    add (golden carrot), (golden apple), (enchanted golden apple), (cookie), (melon slice), (pumpkin pie), (beetroot soup) and (mushroom stew) to {-infuse::flags::consumable_items::*}
    add (rabbit stew), (suspicious stew), (baked potato), (carrot), (potato), (apple), (dried kelp), (chorus fruit), (sweet berries) and (glow berries) to {-infuse::flags::consumable_items::*}
    add (honey bottle), (cod), (salmon), (cooked cod), (cooked salmon), (tropical fish), (pufferfish), (beef), (porkchop), (mutton) and (chicken) to {-infuse::flags::consumable_items::*}
    add (rabbit), (poisonous potato), (spider eye) and (rotten flesh) to {-infuse::flags::consumable_items::*}

    set {-infuse::flags::consumable_filtered::*} to all potions and {-infuse::flags::consumable_items::*}

    set {-infuse::flags::color::emerald} to "#0DFC00"
    set {-infuse::flags::color::feather} to "#BEA3CA"
    set {-infuse::flags::color::fire} to "#FC7803"
    set {-infuse::flags::color::frost} to "#7AE3FC"
    set {-infuse::flags::color::thunder} to "#FCED00"
    set {-infuse::flags::color::haste} to "#B96C00"
    set {-infuse::flags::color::heart} to "#FC0046"
    set {-infuse::flags::color::invisibility} to "#7E00FC"
    set {-infuse::flags::color::ocean} to "#005AFC"
    set {-infuse::flags::color::regeneration} to "#FC00DD"
    set {-infuse::flags::color::speed} to "#D1A44B"
    set {-infuse::flags::color::strength} to "#9E2020"

    # add pale oak log, stripped pale oak log, pale oak wood and stripped pale oak wood to {-infuse::flags::flammable_blocks::*}
