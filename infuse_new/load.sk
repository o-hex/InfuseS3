    # add spruce log, stripped spruce log, spruce wood, stripped spruce wood and spruce leaves to {-infuse::flags::flammable_blocks::*}
    # add spruce planks, spruce slab, spruce stairs, spruce fence and spruce fence gate to {-infuse::flags::flammable_blocks::*}
