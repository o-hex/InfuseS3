# ┳┓┏┓┏┓┏┓┳┓┏┓┳┓┏┓┏┳┓┳┏┓┳┓
# ┣┫┣ ┃┓┣ ┃┃┣ ┣┫┣┫ ┃ ┃┃┃┃┃
# ┛┗┗┛┗┛┗┛┛┗┗┛┛┗┛┗ ┻ ┻┗┛┛┗                        

on right click:
    if {-infuse::flags::consumable_items::*} contains event-item:
        if has_infuse(event-player, "regeneration") is true:       
            if nbt of event-item is a blank nbt compound:
                set custom model data strings of event-item to "infuse:food"
                apply food component to event-item:
                    nutrition: {-infuse::config::regeneration::food}
                    saturation: {-infuse::config::regeneration::saturation}
                    can_always_eat: true
                wait 1.6 seconds
                reset nbt of event-item
        else:
            if custom model data strings of event-item contains "infuse:food":
                reset nbt of event-item

on hunger level change:
    if has_infuse(event-player, "regeneration") is true:
        set the player's food level to 10

