    # if {-infuse::transient::%uuid of player%::rwc} > 0:
    #     subtract 1 from {-infuse::transient::%uuid of player%::rwc}
    #     spawn a wind charge at eye location of player
    #     set {_e} to last spawned entity
    #     set {_dir} to vector from yaw player's yaw and pitch player's pitch
